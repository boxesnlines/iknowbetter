<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <ProjectReference Include="..\IKnowBetter\IKnowBetter.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Reference Include="IKnowBetterTestClassLibrary">
        <HintPath>..\IKnowBetterTestClassLibrary\bin\Release\net10.0\IKnowBetterTestClassLibrary.dll</HintPath>
        <Private>true</Private>
      </Reference>
    </ItemGroup>

    <!--
      Local development path: import the same targets file used by NuGet so the task
      also runs when consuming IKnowBetter through ProjectReference.
      In theory exactly the same thing will happen when importing the NuGet package generated from this project.
    -->
    <PropertyGroup>
        <IKnowBetterTaskAssembly>$(MSBuildThisFileDirectory)..\IKnowBetter\bin\$(Configuration)\net10.0\IKnowBetter.dll</IKnowBetterTaskAssembly>
    </PropertyGroup>

    <Import Project="..\IKnowBetter\buildTransitive\IKnowBetter.targets"
            Condition="Exists('..\IKnowBetter3\buildTransitive\IKnowBetter.targets')" />

</Project>
